{
  "name": "term",
  "version": "0.1.0",
  "private": true,
  "main": ".electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n web,electron:build,electron -c blue,magenta,green \"bun run dev:web\" \"bun run dev:electron:build\" \"bun run dev:electron:app\"",
    "dev:web": "next dev",
    "dev:electron:build": "bun build ./electron/main.ts ./electron/preload.ts --outdir ./.electron --target=node --format=cjs --external electron --external node-pty --watch",
    "dev:electron:app": "wait-on tcp:3000 .electron/main.js .electron/preload.js && ELECTRON_RENDERER_URL=http://localhost:3000 electronmon .electron/main.js",
    "build": "bun run build:web && bun run build:electron",
    "build:web": "next build",
    "build:electron": "bun build ./electron/main.ts ./electron/preload.ts --outdir ./.electron --target=node --format=cjs --external electron --external node-pty",
    "start": "electron .electron/main.js",
    "dist": "bun run build && electron-builder --config electron-builder.yml",
    "lint": "eslint ."
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "electron",
    "electron-winstaller",
    "node-pty",
    "sharp",
    "unrs-resolver"
  ]
}
